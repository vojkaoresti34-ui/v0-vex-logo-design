# DATABASE — PostgreSQL ONLY (Free, no install: https://neon.tech OR https://supabase.com)
# NOTE: This app uses PostgreSQL. XAMPP/MySQL will NOT work.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# AUTH — handled in our own database (email + password, bcrypt, session cookies).
# No third-party auth provider keys are needed.

# GOOGLE GEMINI AI (https://aistudio.google.com)
GEMINI_API_KEY="AIza..."

# GROQ AI FALLBACK (Free: https://console.groq.com — 14,400 req/day)
GROQ_API_KEY="gsk_..."

# RESEND EMAIL (Free: https://resend.com — 3,000 emails/month)
RESEND_API_KEY="re_..."

# UPLOADTHING FILE STORAGE (Free: https://uploadthing.com — 2GB)
UPLOADTHING_TOKEN="..."

# APP URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
